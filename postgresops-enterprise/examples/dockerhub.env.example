# Copy to docker/.env.hub (see Makefile COMPOSE_HUB) for docker-compose.hub.yml

# Public image on Docker Hub
DOCKERHUB_IMAGE=infrayantra/postgresops-control-plane:latest

# Strong random secret (openssl rand -hex 32)
POSTGRESOPS_JWT_SECRET=change-me-use-openssl-rand-hex-32

# Browser origin for CORS (your public URL or http://localhost:8080)
POSTGRESOPS_CORS_ORIGINS=http://localhost:8080

# Optional label surfaced in GET /api/v1/meta
POSTGRESOPS_BUILD_ID=dockerhub
