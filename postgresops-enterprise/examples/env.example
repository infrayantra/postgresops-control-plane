# Control plane database (catalog, tenants, cluster registry)
POSTGRESOPS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:55432/postgresops

POSTGRESOPS_REDIS_URL=redis://localhost:56379/0

POSTGRESOPS_API_HOST=0.0.0.0
POSTGRESOPS_API_PORT=8000
POSTGRESOPS_ENV=development
POSTGRESOPS_JWT_SECRET=change-me-use-openssl-rand-hex-32

# Comma-separated browser origins for CORS, or * (wildcard disables allow_credentials)
POSTGRESOPS_CORS_ORIGINS=http://localhost:8080

# Git SHA / image tag surfaced by GET /api/v1/meta
POSTGRESOPS_BUILD_ID=local

# Set true in containers / log aggregators for JSON logs
POSTGRESOPS_LOG_JSON=false

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=

# AI (optional, future)
OPENAI_API_BASE=
OPENAI_API_KEY=

# --- Docker Hub pull stack (see docs/DOCKER_HUB.md) ---
# Copy docker/env.hub.example → docker/.env.hub and set:
# DOCKERHUB_IMAGE=infrayantra/postgresops-control-plane:latest
